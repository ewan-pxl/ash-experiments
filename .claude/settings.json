{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "git pull --ff-only; exit 0",
            "timeout": 30,
            "statusMessage": "Syncing repo…"
          }
        ]
      }
    ]
  }
}
